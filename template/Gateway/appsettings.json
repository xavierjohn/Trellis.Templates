{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information",
      "Trellis": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "projects-route": {
        "ClusterId": "projects",
        "Match": { "Path": "/api/projects/{**catch-all}" }
      },
      "members-route": {
        "ClusterId": "members",
        "Match": { "Path": "/api/members/{**catch-all}" }
      }
    },
    "Clusters": {
      "projects": {
        "Destinations": {
          "projects/destination1": {
            "Address": "https+http://projects"
          }
        }
      },
      "members": {
        "Destinations": {
          "members/destination1": {
            "Address": "https+http://members"
          }
        }
      }
    }
  }
}
