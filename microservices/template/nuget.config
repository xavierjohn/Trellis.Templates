<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Hermetic NuGet config for the scaffolded Project Tracker.
    <clear/> drops any source inherited from a parent / per-user / per-machine
    config so the build is reproducible on every developer's box. If you need a
    private feed for your organization, add it BELOW the clear and the nuget.org
    entry — and map sources explicitly per
    https://learn.microsoft.com/en-us/nuget/consume-packages/package-source-mapping
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
