<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Imported by Directory.Build.props for every *.Tests project. Wires the xUnit v3 +
       Microsoft.Testing.Platform runner and the shared test dependencies so the test csprojs stay thin. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <!-- CA1707: test method names use underscores. TRLS003: Trellis analyzer relaxed for test code. -->
    <NoWarn>$(NoWarn);CA1707;TRLS003</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Using Include="FluentAssertions" />
    <Using Include="Xunit" />
    <Using Include="Trellis" />
    <Using Include="Trellis.Testing" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Trellis.Testing" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
    <PackageReference Include="Microsoft.Testing.Extensions.TrxReport" />
  </ItemGroup>
</Project>
